# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# SQLite database path
# On Railway: automatically uses /data/ow_bot.db (volume mount)
# Locally: defaults to ./ow_bot.db
DATABASE_PATH=ow_bot.db

# Optional: override API base URLs
OVERFAST_API_BASE=https://overfast-api.tekrop.fr
OWAPI_FALLBACK_BASE=https://owapi.eu

# Stadium feature — Supabase credentials (required for /stadium command)
SUPABASE_STADIUM_URL=https://your-project.supabase.co/rest/v1/rpc/filter_builds_public_v17
SUPABASE_STADIUM_KEY=your_supabase_anon_key_here
