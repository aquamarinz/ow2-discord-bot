# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# PostgreSQL connection (Railway sets this automatically)
# If unset, falls back to local SQLite
DATABASE_URL=

# Optional: SQLite file path (local dev only, ignored if DATABASE_URL is set)
DATABASE_PATH=ow_bot.db

# Optional: override API base URLs
OVERFAST_API_BASE=https://overfast-api.tekrop.fr
OWAPI_FALLBACK_BASE=https://owapi.eu
